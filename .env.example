# Formatura SaaS Environment Variables
# Copy this file to .env and fill in your actual values

# ASAAS Payment Integration
# Get API key from: https://api.asaas.com
ASAAS_API_KEY=your-asaas-api-key-here

# WhatsApp Integration
# Get API credentials from WhatsApp Business API
WHATSAPP_API_KEY=your-whatsapp-api-key-here

# Google Calendar Integration (Optional)
# Get API key from Google Cloud Console
GOOGLE_CALENDAR_API_KEY=your-google-calendar-api-key-here

# Application Configuration
NODE_ENV=development
PORT=3000
